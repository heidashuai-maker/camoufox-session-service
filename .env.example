# HTTP 服务
HOST=0.0.0.0
PORT=3000

# 可选鉴权；为空时不校验 Bearer Token
AUTH_TOKEN=

# Worker 与队列
CAMOUFOX_WORKERS=1
CAMOUFOX_QUEUE_SIZE=8
CAMOUFOX_TASK_TIMEOUT_SECONDS=120

# Session 与 Worker 回收
CAMOUFOX_SESSION_TTL_SECONDS=900
CAMOUFOX_MAX_JOBS_PER_WORKER=50
CAMOUFOX_MAX_WORKER_LIFETIME_SECONDS=1800
CAMOUFOX_MAX_WORKER_RSS_MB=1536

# 浏览器运行模式：true、false 或 virtual
CAMOUFOX_HEADLESS=true

# 整页 Cloudflare Challenge：每个 Worker 复用 Chromium，每个任务隔离 Context
CHALLENGE_WORKERS=1
CHALLENGE_QUEUE_SIZE=2
CHALLENGE_TASK_TIMEOUT_SECONDS=180
CHALLENGE_MAX_JOBS_PER_WORKER=10
CHALLENGE_MAX_WORKER_LIFETIME_SECONDS=900
CHALLENGE_MAX_WORKER_RSS_MB=2048

# Docker 镜像默认值；非容器环境可改为本机 Chromium 路径
CHROMIUM_PATH=/usr/bin/chromium
